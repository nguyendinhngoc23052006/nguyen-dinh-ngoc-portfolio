---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import ContactForm from "../components/ContactForm";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import MobileNav from "../components/MobileNav";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import ThemeToggle from "../components/ThemeToggle";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import {
  aboutIntro,
  faq,
  heroSubhead,
  navLinks,
  pricing,
  process,
  projects,
  SITE_URL,
  services,
  skills,
  stats,
} from "../data/portfolio";
import "../styles/globals.css";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const error = Astro.locals.startupError;

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const DESCRIPTION =
  "Custom web applications & bespoke software built to your spec. Transparent pricing, deep customization, 100% code ownership. Full-stack development from Hanoi, serving businesses globally.";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#person`,
      name: "Nguyen Dinh Ngoc",
      alternateName: "Jade",
      jobTitle: "Full-Stack Developer",
      description:
        "Full-stack developer building custom web applications and bespoke software for businesses worldwide.",
      url: SITE_URL,
      image: "https://avatars.githubusercontent.com/u/256027763?v=4",
      sameAs: ["https://github.com/nguyendinhngoc23052006"],
      address: {
        "@type": "PostalAddress",
        addressLocality: "Hanoi",
        addressCountry: "VN",
      },
    },
    {
      "@type": "Service",
      "@id": `${SITE_URL}/#service`,
      serviceType: "Custom Software Development",
      provider: { "@id": `${SITE_URL}/#person` },
      areaServed: "Worldwide",
      description:
        "Custom web applications, automation tooling, cloud infrastructure, API integrations, migrations, and development consulting.",
      offers: pricing.map((tier) => ({
        "@type": "Offer",
        name: tier.name,
        description: tier.tagline,
        priceSpecification: {
          "@type": "PriceSpecification",
          priceCurrency: "USD",
          price: tier.priceHint,
        },
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${SITE_URL}/#faq`,
      mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.question,
        acceptedAnswer: { "@type": "Answer", text: f.answer },
      })),
    },
  ],
}).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={DESCRIPTION} />
    <meta name="keywords" content="custom web development, bespoke software, full-stack developer, web applications, business software, deep customization, transparent pricing, Hanoi developer, production-ready apps, software consulting, API integrations, cloud infrastructure" />
    <meta name="author" content="Jade (Nguyen Dinh Ngoc)" />
    <link rel="canonical" href={SITE_URL} />
    <title>Jade — Custom Web Development & Bespoke Software | Nguyen Dinh Ngoc</title>
    <script is:inline>
      (function () {
        function getTheme() {
          const stored = localStorage.getItem('theme');
          if (stored === 'light' || stored === 'dark') return stored;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', getTheme());
        window.addEventListener('storage', function (e) {
          if (e.key === 'theme' && (e.newValue === 'light' || e.newValue === 'dark')) {
            document.documentElement.setAttribute('data-theme', e.newValue);
          }
        });
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="Jade — Custom Web Development & Bespoke Software" />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:image" content="https://avatars.githubusercontent.com/u/256027763?v=4" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Jade — Custom Web Development & Bespoke Software" />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="theme-color" content="#0a0a0a" />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    {error ? (
      <p class="p-8 font-mono text-red-400">Configuration error: {error}</p>
    ) : (
      <>
        <a href="#about" class="skip-link">Skip to content</a>

        {/* ── NAV ── */}
        <header class="fixed inset-x-0 top-0 z-50 border-b border-border/40 bg-background/80 backdrop-blur-lg">
          <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6" aria-label="Main navigation">
            <a href="/" class="text-sm font-bold tracking-tight">Jade</a>
            <div class="hidden items-center gap-5 lg:flex">
              {navLinks.map(({ href, label }) => (
                <a href={href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{label}</a>
              ))}
            </div>
            <div class="flex items-center gap-3">
              <ThemeToggle client:load />
              <MobileNav client:load />
            </div>
          </nav>
        </header>

        {/* ── HERO ── */}
        <section class="relative flex min-h-screen items-center overflow-hidden pt-14">
          <div class="relative mx-auto max-w-5xl px-6 flex flex-col-reverse items-start gap-10 lg:flex-row lg:items-center lg:justify-between">
            <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-muted-foreground">Jade</p>
            <h1 class="mt-2 text-5xl font-extrabold tracking-tighter sm:text-7xl lg:text-8xl">
              Nguyen<br />
              Dinh Ngoc
            </h1>

            <p class="mt-4 max-w-lg text-lg text-muted-foreground sm:text-xl">
              {heroSubhead}
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#contact" class="inline-flex h-10 items-center gap-2 rounded-sm border border-foreground bg-foreground text-background px-6 text-sm font-medium transition-colors hover:bg-transparent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Get a quote
              </a>
              <a href="#pricing" class="inline-flex h-10 items-center gap-2 rounded-sm border border-accent px-6 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                See pricing
              </a>
            </div>
            </div>
            <img
              src="https://avatars.githubusercontent.com/u/256027763?v=4"
              alt="Jade — Nguyen Dinh Ngoc, full-stack developer"
              width="280"
              height="280"
              loading="eager"
              class="rounded-sm border border-border/60 object-cover"
            />
          </div>
        </section>

        {/* ── STATS STRIP ── */}
        <section class="relative border-t border-border/40 bg-card/50 py-10" aria-label="Key facts">
          <div class="mx-auto max-w-5xl px-6">
            <div class="grid gap-6 sm:grid-cols-3">
              {stats.map(({ number, label }) => (
                <div class="text-center sm:text-left">
                  <p class="text-3xl font-extrabold tracking-tight sm:text-4xl">
                    {number}
                  </p>
                  <p class="mt-1 text-sm text-muted-foreground">{label}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── ABOUT ── */}
        <section id="about" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="section-label">About</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Building from Vietnam, shipping globally</h2>

            <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_320px]">
              <div class="space-y-4 text-muted-foreground">
                <p>
                  {aboutIntro}
                </p>
                <p>
                  My work spans the full stack — from database schema and server logic to polished UIs
                  and cloud deployment pipelines. I specialize in building bespoke tools: internal
                  dashboards, automation systems, client portals, and anything that doesn't fit a
                  template.
                </p>
              </div>

              <aside class="border-l-4 border-accent bg-secondary/30 p-6 space-y-5">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Location</p>
                  <p class="mt-0.5 text-sm">Hanoi, Vietnam</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Education</p>
                  <p class="mt-0.5 text-sm">Foreign Trade University (FTU)</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Focus</p>
                  <p class="mt-0.5 text-sm">Web apps · Automation · Cloud infra</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Status</p>
                  <p class="mt-0.5 text-sm text-accent">Open to projects</p>
                </div>
              </aside>
            </div>
          </div>
        </section>

        {/* ── SERVICES ── */}
        <section id="services" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="section-label">Services</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Custom software built to your spec</h2>
            <p class="mt-3 max-w-2xl text-muted-foreground">
              Deep customization for every business need — from single-feature tools to full-scale
              applications. Pick a service or combine several.
            </p>

            <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {services.map(({ title, desc, cta }) => (
                <div class="rounded-sm border border-border/60 bg-card p-6">
                  <h3 class="font-semibold tracking-tight">{title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{desc}</p>
                  <a href="#contact" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent">
                    {cta} <span aria-hidden="true">&rarr;</span>
                  </a>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── PRICING ── */}
        <section id="pricing" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="section-label">Pricing</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Transparent, fixed-price development</h2>
            <p class="mt-3 max-w-2xl text-muted-foreground">
              Quotes are locked in before we start. No hidden fees, no surprise invoices, no
              hourly-billing padding.
            </p>

            <div class="mt-10 grid gap-6 lg:grid-cols-3">
              {pricing.map((tier) => (
                <div
                  class:list={[
                    "relative rounded-sm border p-6",
                    tier.recommended
                      ? "border-accent bg-background"
                      : "border-border/60 bg-background",
                  ]}
                >
                  {tier.recommended && (
                    <p class="text-xs font-bold uppercase tracking-widest text-accent mb-2">
                      Most popular
                    </p>
                  )}
                  <h3 class="text-lg font-bold tracking-tight">{tier.name}</h3>
                  <p class="mt-1 text-sm text-muted-foreground">{tier.tagline}</p>
                  <p class="mt-4 text-3xl font-extrabold tracking-tight">{tier.priceHint}</p>
                  <ul class="mt-6 space-y-2.5">
                    {tier.features.map((feature) => (
                      <li class="flex items-start gap-2 text-sm">
                        <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-accent/15 text-accent" aria-hidden="true">
                          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12" />
                          </svg>
                        </span>
                        <span class="text-muted-foreground">{feature}</span>
                      </li>
                    ))}
                  </ul>
                  <a
                    href="#contact"
                    class:list={[
                      "mt-6 inline-flex h-10 w-full items-center justify-center rounded-sm px-4 text-sm font-medium transition-colors",
                      tier.recommended
                        ? "bg-accent text-accent-foreground hover:bg-accent/90"
                        : "border border-input bg-background hover:bg-muted",
                    ]}
                  >
                    {tier.cta}
                  </a>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm text-muted-foreground">
              Need something outside these tiers? <a href="#contact" class="text-accent hover:underline">Let's talk</a> — every project can be scoped custom.
            </p>
          </div>
        </section>

        {/* ── PROCESS ── */}
        <section id="process" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="section-label">Process</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">How we build your application</h2>

            <div class="mt-12 hidden md:grid md:grid-cols-4 md:gap-8 md:relative">
              <div class="absolute top-8 left-16 right-16 h-px bg-border" aria-hidden="true" />
              {process.map(({ num, title, desc }) => (
                <div class="relative z-10 text-center">
                  <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border-2 border-foreground bg-background text-lg font-bold">
                    {num}
                  </div>
                  <h3 class="mt-4 font-semibold tracking-tight">{title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{desc}</p>
                </div>
              ))}
            </div>

            <div class="mt-10 space-y-6 md:hidden">
              {process.map(({ num, title, desc }) => (
                <div class="flex gap-4">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border-2 border-foreground bg-background text-sm font-bold">
                    {num}
                  </div>
                  <div>
                    <h3 class="font-semibold tracking-tight">{title}</h3>
                    <p class="mt-1 text-sm text-muted-foreground leading-relaxed">{desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── SKILLS ── */}
        <section id="skills" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="section-label">Stack</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Technologies I work with</h2>

            <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {skills.map(({ group, items }) => (
                <div class="rounded-sm border border-border/60 bg-background/50 p-5">
                  <p class="mb-3 text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">{group}</p>
                  <div class="flex flex-wrap gap-2">
                    {items.map((s) => (
                      <span class="rounded-sm border border-border/60 bg-secondary/30 px-2.5 py-0.5 text-xs font-medium">
                        {s}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── PROJECTS ── */}
        <section id="projects" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="section-label">Projects</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">What I'm building</h2>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              {projects.map(({ num, title, desc, tags }) => (
                <div class="relative rounded-sm border border-border/60 bg-card p-6">
                  <span class="text-4xl font-black text-border/40 select-none">{num}</span>
                  <p class="mt-3 text-xs font-medium text-muted-foreground uppercase tracking-widest">
                    In progress
                  </p>
                  <h3 class="mt-3 font-semibold tracking-tight">{title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{desc}</p>
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((t) => (
                      <span class="rounded-sm border border-border/60 bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8 flex items-center gap-4">
              <a href="https://github.com/nguyendinhngoc23052006" target="_blank" rel="noopener noreferrer" class="inline-flex h-10 items-center gap-2 rounded-sm border border-input bg-background px-6 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Follow on GitHub <span aria-hidden="true">&rarr;</span>
              </a>
              <p class="text-sm text-muted-foreground">Stay updated as these ship.</p>
            </div>
          </div>
        </section>

        {/* ── FAQ ── */}
        <section id="faq" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-3xl px-6">
            <p class="section-label">FAQ</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Questions about custom development</h2>

            <div class="mt-10">
              {faq.map(({ question, answer }) => (
                <details class="faq-item">
                  <summary>{question}</summary>
                  <div class="faq-answer">{answer}</div>
                </details>
              ))}
            </div>
          </div>
        </section>

        {/* ── CONTACT ── */}
        <section id="contact" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-xl px-6">
            <p class="section-label">Contact</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Start a conversation</h2>
            <p class="mt-3 text-muted-foreground">
              Have a project in mind? Tell me about it and I'll respond within 24 hours.
            </p>
            <div class="mt-8">
              <ContactForm client:load />
            </div>
          </div>
        </section>

        {/* ── FOOTER ── */}
        <footer class="border-t border-border/40 py-8">
          <div class="mx-auto max-w-5xl px-6 text-center">
            <div class="flex justify-center gap-6">
              <a href="https://github.com/nguyendinhngoc23052006" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground transition-colors hover:text-foreground">GitHub</a>
              <a href="mailto:dinhnhuong1969@gmail.com" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Email</a>
            </div>
            <p class="mt-4 text-xs text-muted-foreground">
              &copy; {new Date().getFullYear()} Jade &middot; Nguyen Dinh Ngoc &middot; Custom web development from Hanoi
            </p>
          </div>
        </footer>

      </>
    )}
  </body>
</html>
