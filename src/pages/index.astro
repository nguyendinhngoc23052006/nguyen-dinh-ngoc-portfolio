---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import ContactForm from "../components/ContactForm";
import "../styles/globals.css";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const error = Astro.locals.startupError;

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const skills = [
  {
    group: "Languages",
    items: [
      "TypeScript",
      "JavaScript",
      "Python",
      "Go",
      "Rust",
      "Java",
      "C++",
      "PHP",
      "SQL",
    ],
  },
  {
    group: "Frontend",
    items: [
      "React",
      "Next.js",
      "Astro",
      "Vue",
      "Svelte",
      "Tailwind CSS",
      "Three.js",
      "Vite",
    ],
  },
  {
    group: "Backend",
    items: [
      "Node.js",
      "Bun",
      "Deno",
      "Express",
      "Hono",
      "FastAPI",
      "Django",
      "Flask",
      "Gin",
      "tRPC",
    ],
  },
  {
    group: "Cloud & Infra",
    items: [
      "Cloudflare Workers",
      "Supabase",
      "AWS",
      "GCP",
      "Docker",
      "GitHub Actions",
      "Vercel",
      "Terraform",
    ],
  },
  {
    group: "Databases",
    items: [
      "PostgreSQL",
      "MySQL",
      "MongoDB",
      "Redis",
      "SQLite",
      "Prisma",
      "Drizzle",
    ],
  },
];

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const projects = [
  {
    title: "Project One",
    desc: "A placeholder for a real project. Description, impact, and a link will go here once the work is ready to showcase.",
    tags: ["TypeScript", "React", "PostgreSQL"],
  },
  {
    title: "Project Two",
    desc: "Another placeholder. Real projects with live links and outcome metrics will replace these cards.",
    tags: ["Python", "FastAPI", "Docker"],
  },
  {
    title: "Project Three",
    desc: "More coming. The pipeline is live; the showcase content is being curated and added soon.",
    tags: ["Go", "Cloudflare", "Supabase"],
  },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Nguyen Dinh Ngoc — Custom Solutions Developer. Building end-to-end digital products from Vietnam." />
    <title>Nguyen Dinh Ngoc</title>
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    {error ? (
      <p class="p-8 font-mono text-red-400">Configuration error: {error}</p>
    ) : (
      <>
        {/* ── NAV ── */}
        <header class="fixed inset-x-0 top-0 z-50 border-b border-border/40 bg-background/80 backdrop-blur-lg">
          <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6">
            <a href="/" class="text-sm font-bold tracking-tight">NĐN</a>
            <div class="hidden items-center gap-6 sm:flex">
              <a href="#about" class="text-sm text-muted-foreground transition-colors hover:text-foreground">About</a>
              <a href="#skills" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Skills</a>
              <a href="#projects" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Projects</a>
              <a href="#contact" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Contact</a>
            </div>
          </nav>
        </header>

        {/* ── HERO ── */}
        <section class="relative flex min-h-screen items-center overflow-hidden pt-14">
          <div class="pointer-events-none absolute -left-32 -top-32 h-[500px] w-[500px] rounded-full bg-blue-500/5 blur-3xl" />
          <div class="pointer-events-none absolute -bottom-32 -right-32 h-[400px] w-[400px] rounded-full bg-violet-500/5 blur-3xl" />

          <div class="relative mx-auto max-w-5xl px-6 flex flex-col-reverse items-start gap-10 lg:flex-row lg:items-center lg:justify-between">
            <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-secondary/50 px-3 py-1 text-xs text-muted-foreground">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_6px] shadow-emerald-500 animate-pulse" />
              Available for projects
            </div>

            <h1 class="mt-6 text-5xl font-extrabold tracking-tighter sm:text-7xl lg:text-8xl">
              Nguyen<br />
              Dinh <span class="bg-gradient-to-br from-blue-400 to-violet-500 bg-clip-text text-transparent">Ngoc</span>
            </h1>

            <p class="mt-4 max-w-lg text-lg text-muted-foreground sm:text-xl">
              Custom solutions developer — I turn ideas into production-ready digital products, fast.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#contact" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow-xs transition-colors hover:bg-primary/90">
                Request a demo
              </a>
              <a href="#projects" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-xs transition-colors hover:bg-accent hover:text-accent-foreground">
                See my work
              </a>
            </div>
            </div>
            <img
              src="https://avatars.githubusercontent.com/u/256027763?v=4"
              alt="Nguyen Dinh Ngoc"
              width="280"
              height="280"
              class="rounded-2xl border border-border/60 shadow-lg shadow-blue-500/5 object-cover"
            />
          </div>
        </section>

        {/* ── ABOUT ── */}
        <section id="about" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">About</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Building from Vietnam, shipping globally</h2>

            <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_320px]">
              <div class="space-y-4 text-muted-foreground">
                <p>
                  I'm a 19-year-old custom solutions developer based in Hanoi, currently studying
                  International Business at Foreign Trade University (FTU). I started writing code to
                  solve real problems, and never stopped.
                </p>
                <p>
                  My work spans the full stack — from database schema and server logic to polished UIs
                  and cloud deployment pipelines. I specialize in building bespoke tools: internal
                  dashboards, automation systems, client portals, and anything that doesn't fit a
                  template.
                </p>
                <p>
                  Fast turnaround, clean architecture, and no unnecessary complexity — that's the
                  standard I hold every project to.
                </p>
              </div>

              <div class="rounded-xl border border-border/60 bg-secondary/30 p-6 space-y-5">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Location</p>
                  <p class="mt-0.5 text-sm">Hanoi, Vietnam</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Education</p>
                  <p class="mt-0.5 text-sm">Foreign Trade University (FTU)</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Born</p>
                  <p class="mt-0.5 text-sm">May 23, 2006</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Focus</p>
                  <p class="mt-0.5 text-sm">Web apps · Automation · Cloud infra</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Status</p>
                  <p class="mt-0.5 text-sm text-emerald-400">Open to projects</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        {/* ── SKILLS ── */}
        <section id="skills" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Stack</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Languages & frameworks</h2>

            <div class="mt-10 space-y-8">
              {skills.map(({ group, items }) => (
                <div>
                  <p class="mb-3 text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">{group}</p>
                  <div class="flex flex-wrap gap-2">
                    {items.map((s) => (
                      <span class="rounded-md border border-border/60 bg-secondary/30 px-2.5 py-0.5 text-xs font-medium transition-colors hover:border-blue-400/40 hover:text-blue-400">
                        {s}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── PROJECTS ── */}
        <section id="projects" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Projects</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Selected work</h2>

            <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {projects.map(({ title, desc, tags }) => (
                <div class="group rounded-xl border border-border/60 bg-card p-6 transition-all hover:border-blue-400/30 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/5">
                  <div class="flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">
                    <span class="h-1.5 w-1.5 rounded-full bg-muted-foreground" />
                    Coming soon
                  </div>
                  <h3 class="mt-3 font-semibold tracking-tight">{title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{desc}</p>
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((t) => (
                      <span class="rounded border border-blue-400/20 bg-blue-400/5 px-2 py-0.5 text-[11px] font-medium text-blue-400">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── CONTACT ── */}
        <section id="contact" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Contact</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Let's build something</h2>
            <p class="mt-3 text-muted-foreground">
              Got a project in mind? Fill in the form and I'll get back to you within 24 hours.
            </p>
            <div class="mt-8">
              <ContactForm client:load />
            </div>
          </div>
        </section>

        {/* ── FOOTER ── */}
        <footer class="border-t border-border/40 py-8">
          <div class="mx-auto max-w-5xl px-6 text-center">
            <div class="flex justify-center gap-6">
              <a href="#" class="text-sm text-muted-foreground transition-colors hover:text-foreground">GitHub</a>
              <a href="#" class="text-sm text-muted-foreground transition-colors hover:text-foreground">LinkedIn</a>
              <a href="mailto:placeholder@example.com" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Email</a>
            </div>
            <p class="mt-4 text-xs text-muted-foreground">
              © {new Date().getFullYear()} Nguyen Dinh Ngoc. All rights reserved.
            </p>
          </div>
        </footer>
      </>
    )}
  </body>
</html>
