---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import ContactForm from "../components/ContactForm";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below the frontmatter fence
import MobileNav from "../components/MobileNav";
import "../styles/globals.css";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const error = Astro.locals.startupError;

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const skills = [
  {
    group: "Languages",
    items: ["TypeScript", "JavaScript", "Python", "SQL"],
  },
  {
    group: "Frontend",
    items: ["React", "Next.js", "Astro", "Tailwind CSS"],
  },
  {
    group: "Backend",
    items: ["Node.js", "Express", "Hono", "FastAPI"],
  },
  {
    group: "Cloud & DevOps",
    items: ["Cloudflare Workers", "Supabase", "GitHub Actions", "Docker"],
  },
  {
    group: "Databases",
    items: ["PostgreSQL", "Redis"],
  },
];

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const projects = [
  {
    title: "Project One",
    desc: "Coming soon — a full-stack application currently in development. Check back for updates or visit my GitHub for the latest.",
    tags: ["React", "TypeScript", "Supabase"],
    href: "https://github.com/nguyendinhngoc23052006",
  },
  {
    title: "Project Two",
    desc: "Coming soon — another project in the pipeline. Follow along on GitHub to see it take shape.",
    tags: ["Node.js", "Cloudflare Workers", "PostgreSQL"],
    href: "https://github.com/nguyendinhngoc23052006",
  },
];

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nguyen Dinh Ngoc",
  alternateName: "Jade",
  jobTitle: "Full-Stack Developer",
  sameAs: ["https://github.com/nguyendinhngoc23052006"],
});
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Jade (Nguyen Dinh Ngoc) — Full-stack developer based in Hanoi. Building production-ready web applications with modern cloud infrastructure." />
    <title>Jade — Full-Stack Developer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="Jade (Nguyen Dinh Ngoc) — Full-Stack Developer" />
    <meta property="og:description" content="Full-stack developer based in Hanoi. Building production-ready web applications with modern cloud infrastructure." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://avatars.githubusercontent.com/u/256027763?v=4" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Jade (Nguyen Dinh Ngoc) — Full-Stack Developer" />
    <meta name="twitter:description" content="Full-stack developer based in Hanoi. Building production-ready web applications." />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    {error ? (
      <p class="p-8 font-mono text-red-400">Configuration error: {error}</p>
    ) : (
      <>
        {/* Skip to main content */}
        <a href="#about" class="skip-link">Skip to content</a>

        {/* ── NAV ── */}
        <header class="fixed inset-x-0 top-0 z-50 border-b border-border/40 bg-background/80 backdrop-blur-lg">
          <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6" aria-label="Main navigation">
            <a href="/" class="text-sm font-bold tracking-tight">Jade</a>
            <div class="hidden items-center gap-6 sm:flex">
              <a href="#about" class="text-sm text-muted-foreground transition-colors hover:text-foreground">About</a>
              <a href="#skills" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Skills</a>
              <a href="#projects" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Projects</a>
              <a href="#contact" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Contact</a>
            </div>
            <MobileNav client:load />
          </nav>
        </header>

        {/* ── HERO ── */}
        <section class="relative flex min-h-screen items-center overflow-hidden pt-14">
          <div class="hero-glow pointer-events-none absolute -left-32 -top-32 h-[500px] w-[500px] rounded-full bg-emerald-500/5 blur-3xl" />
          <div class="hero-glow pointer-events-none absolute -bottom-32 -right-32 h-[400px] w-[400px] rounded-full bg-blue-500/5 blur-3xl" />

          <div class="relative mx-auto max-w-5xl px-6 flex flex-col-reverse items-start gap-10 lg:flex-row lg:items-center lg:justify-between">
            <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-secondary/50 px-3 py-1 text-xs text-muted-foreground">
              <span class="pulse-dot h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_6px] shadow-emerald-500" aria-hidden="true" />
              Available for projects
            </div>

            <p class="mt-6 text-sm font-semibold uppercase tracking-widest bg-gradient-to-r from-emerald-400 to-blue-400 bg-clip-text text-transparent">Jade</p>
            <h1 class="mt-2 text-5xl font-extrabold tracking-tighter sm:text-7xl lg:text-8xl">
              Nguyen<br />
              Dinh <span class="bg-gradient-to-br from-emerald-400 to-blue-500 bg-clip-text text-transparent">Ngoc</span>
            </h1>

            <p class="mt-4 max-w-lg text-lg text-muted-foreground sm:text-xl">
              Full-stack developer — I turn ideas into production-ready web applications, fast.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href="#contact" class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow-xs transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                Get in touch
              </a>
              <a href="#projects" class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-6 text-sm font-medium shadow-xs transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                See my work
              </a>
            </div>
            </div>
            <img
              src="https://avatars.githubusercontent.com/u/256027763?v=4"
              alt="Jade — Nguyen Dinh Ngoc"
              width="280"
              height="280"
              loading="eager"
              class="rounded-2xl border border-border/60 shadow-lg shadow-emerald-500/5 object-cover"
            />
          </div>
        </section>

        {/* ── ABOUT ── */}
        <section id="about" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">About</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Building from Vietnam, shipping globally</h2>

            <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_320px]">
              <div class="space-y-4 text-muted-foreground">
                <p>
                  I'm a full-stack developer based in Hanoi, currently studying International Business
                  at Foreign Trade University (FTU). I started writing code to solve real problems, and
                  never stopped.
                </p>
                <p>
                  My work spans the full stack — from database schema and server logic to polished UIs
                  and cloud deployment pipelines. I specialize in building bespoke tools: internal
                  dashboards, automation systems, client portals, and anything that doesn't fit a
                  template.
                </p>
                <p>
                  Fast turnaround, clean architecture, and no unnecessary complexity — that's the
                  standard I hold every project to.
                </p>
              </div>

              <div class="rounded-xl border border-border/60 bg-secondary/30 p-6 space-y-5">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Location</p>
                  <p class="mt-0.5 text-sm">Hanoi, Vietnam</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Education</p>
                  <p class="mt-0.5 text-sm">Foreign Trade University (FTU)</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Focus</p>
                  <p class="mt-0.5 text-sm">Web apps · Automation · Cloud infra</p>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Status</p>
                  <p class="mt-0.5 text-sm text-emerald-400">Open to projects</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        {/* ── SKILLS ── */}
        <section id="skills" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Stack</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Technologies I work with</h2>

            <div class="mt-10 space-y-8">
              {skills.map(({ group, items }) => (
                <div>
                  <p class="mb-3 text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">{group}</p>
                  <div class="flex flex-wrap gap-2">
                    {items.map((s) => (
                      <span class="rounded-md border border-border/60 bg-secondary/30 px-2.5 py-0.5 text-xs font-medium transition-colors hover:border-blue-400/40 hover:text-blue-400">
                        {s}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── PROJECTS ── */}
        <section id="projects" class="border-t border-border/40 bg-card/50 py-20 sm:py-28">
          <div class="mx-auto max-w-5xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Projects</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">What I've built</h2>

            <div class="mt-10 grid gap-4 sm:grid-cols-2">
              {projects.map(({ title, desc, tags, href }) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group rounded-xl border border-border/60 bg-card p-6 transition-all hover:border-blue-400/30 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                >
                  <h3 class="font-semibold tracking-tight group-hover:text-blue-400 transition-colors">{title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{desc}</p>
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {tags.map((t) => (
                      <span class="rounded border border-blue-400/20 bg-blue-400/5 px-2 py-0.5 text-[11px] font-medium text-blue-400">
                        {t}
                      </span>
                    ))}
                  </div>
                </a>
              ))}
            </div>

            <p class="mt-8 text-sm text-muted-foreground">
              More on <a href="https://github.com/nguyendinhngoc23052006" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:underline">GitHub</a>.
            </p>
          </div>
        </section>

        {/* ── CONTACT ── */}
        <section id="contact" class="border-t border-border/40 py-20 sm:py-28">
          <div class="mx-auto max-w-xl px-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Contact</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Start a conversation</h2>
            <p class="mt-3 text-muted-foreground">
              Have a project in mind? Tell me about it and I'll respond within 24 hours.
            </p>
            <div class="mt-8">
              <ContactForm client:load />
            </div>
          </div>
        </section>

        {/* ── FOOTER ── */}
        <footer class="border-t border-border/40 py-8">
          <div class="mx-auto max-w-5xl px-6 text-center">
            <div class="flex justify-center gap-6">
              <a href="https://github.com/nguyendinhngoc23052006" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground transition-colors hover:text-foreground">GitHub</a>
              <a href="mailto:dinhnhuong1969@gmail.com" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Email</a>
            </div>
            <p class="mt-4 text-xs text-muted-foreground">
              &copy; {new Date().getFullYear()} Jade &middot; Nguyen Dinh Ngoc
            </p>
          </div>
        </footer>
      </>
    )}
  </body>
</html>
